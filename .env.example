# ─── NEXUS RAG — Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ── LLM (Groq) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=GROQ_API_KEY=your_groq_api_key_here

# ── Model settings (optional overrides) ──────────────────────────────────────
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_TEMP=0.15
GROQ_MAX_TOKENS=2048

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBED_MODEL="all-MiniLM-L6-v2"

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=550
CHUNK_OVERLAP=80

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=5
FETCH_K=14
MMR_LAMBDA=0.65

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
